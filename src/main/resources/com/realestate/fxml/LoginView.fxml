<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.realestate.view.LoginController"
            prefWidth="420" prefHeight="500"
            styleClass="auth-root">

    <center>
        <VBox spacing="16" alignment="CENTER" styleClass="auth-card">
            <Label text="🏠 RealEstate" styleClass="app-title"/>
            <Label text="Войдите в аккаунт" styleClass="subtitle"/>

            <TextField fx:id="emailField" promptText="Email" styleClass="field"/>
            <PasswordField fx:id="passField" promptText="Пароль" styleClass="field"/>

            <Label fx:id="errorLabel" styleClass="error-label" managed="false" visible="false"/>

            <Button fx:id="loginBtn" text="Войти" onAction="#onLogin"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Separator/>

            <Button text="Продолжить как гость" onAction="#onGuest"
                    styleClass="btn-secondary" maxWidth="Infinity"/>

            <Hyperlink text="Нет аккаунта? Зарегистрироваться" onAction="#onRegister"
                       styleClass="link"/>
        </VBox>
    </center>
</BorderPane>
